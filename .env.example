# ===== Hurtz Cérebro — variáveis de ambiente =====
# Copie esse arquivo pra .env e preencha com seus valores reais.
# .env é ignorado pelo git (cada gestor tem o seu).

# Identidade do gestor que está rodando esse Claude Code
# Slug deve bater com colaboradores/{slug}/
HURTZ_GESTOR=

# ===== Evolution API (WhatsApp) =====
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
EVOLUTION_GROUP_OPERACIONAL=

# ===== Meta Ads =====
META_FORM_ID=
META_PAGE_ID=
META_PAGE_TOKEN=
META_SHEET_ID=

# ===== Google APIs (Sheets, Docs, Drive, Calendar) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ===== OpenRouter (geração de imagens) =====
OPENROUTER_API_KEY=

# ===== Cloudflare Pages (publicação) =====
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ===== ClickUp (Fase 2 — sync de tarefas) =====
# CLICKUP_API_TOKEN=
# CLICKUP_TEAM_ID=
# CLICKUP_LIST_ID=
